="4"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Refinery Explorer:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> A Mapbox-powered global map showing refinery locations. Clicking a node displays a "mini-Sankey" of </w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Inputs</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> (Crude types) vs. </w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Outputs</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> (Gasoline, Diesel, Jet Fuel).</w:t></w:r></w:p><w:p w14:paraId="14D15021" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Global Reserves Map:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> A 3D Choropleth or Bubble map visualizing proved oil reserves by country.</w:t></w:r></w:p><w:p w14:paraId="3CFBD05D" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Spot Price Terminal:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> Interactive line charts for WTI, Brent, and regional blends with time-frame toggles (1D to 30Y).</w:t></w:r></w:p><w:p w14:paraId="2375597A" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Oil Type Breakdown:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> Interactive Treemaps showing global production and use categorized by density (Light/Heavy) and sulfur content (Sweet/Sour).</w:t></w:r></w:p><w:p w14:paraId="45EEEAFF" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"/><w:p w14:paraId="7113531F" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"/><w:p w14:paraId="67F6610E" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>D. Phase 3: AI Intelligence (Chat with Data)</w:t></w:r></w:p><w:p w14:paraId="71F637B7" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Goal:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> Natural language querying of the repository.</w:t></w:r></w:p><w:p w14:paraId="0DC45B53" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Feature:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> "The Oil Analyst" Chat Sidebar.</w:t></w:r></w:p><w:p w14:paraId="40F02BBC" w14:textId="1A1A3CDC" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Workflow:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> User asks a question </w:t></w:r><w:r><w:sym w:font="Wingdings" w:char="F0E0"/></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> AI generates read-only SQL for Neon </w:t></w:r><w:r><w:sym w:font="Wingdings" w:char="F0E0"/></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> AI summarizes findings using the specific datasets retrieved.</w:t></w:r></w:p><w:p w14:paraId="58CAA80F" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>E. Phase 4: Extended Scrapers (Non-API Data)</w:t></w:r></w:p><w:p w14:paraId="719E1C57" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Goal:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> Capture the "messy" data that lacks official APIs.</w:t></w:r></w:p><w:p w14:paraId="59B22E17" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Sources:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> JODI Oil CSVs (Global Production), Argus Media RSS (Maintenance/Outages), and Vessel Tracking (AIS web-scrapes).</w:t></w:r></w:p><w:p w14:paraId="239F0532" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>3. Cursor Vibe-Coding Instructions</w:t></w:r></w:p><w:p w14:paraId="269704AA" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>API Ingestion Logic</w:t></w:r></w:p><w:p w14:paraId="0A9ABBC3" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:r w:rsidRPr="001A5CB5"><w:t>"Implement the Next.js API routes for api/ingest/eia and api/ingest/oilprice. Use the EIA v2 API for crude grades and the OilPriceAPI free tier for spot prices. Ensure data is mapped to the fact_prices and fact_shipments tables in Neon. Use CRON_SECRET for protection."</w:t></w:r></w:p><w:p w14:paraId="6D21DEAF" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Mapping &amp; Visualization Logic</w:t></w:r></w:p><w:p w14:paraId="4768DE47" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:r w:rsidRPr="001A5CB5"><w:t>"Using Mapbox GL and Apache ECharts, build the 'Refinery Explorer' component. It should pull from dim_refineries and fact_production. When a refinery is clicked, show a side-panel detailing its specific input/output yield."</w:t></w:r></w:p><w:p w14:paraId="05EF2035" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"/><w:p w14:paraId="17F2CDFE" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"/><w:p w14:paraId="1D2429A1" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>4. Success Metrics for Verification</w:t></w:r></w:p><w:p w14:paraId="0F5DC52E" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve">[ ] </w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>API Health:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> fact_prices updates daily via cron-job.org triggers.</w:t></w:r></w:p><w:p w14:paraId="1B623853" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve">[ ] </w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Visual Accuracy:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> Refinery map correctly places assets and reflects IEA/EIA capacity data.</w:t></w:r></w:p><w:p w14:paraId="22178DFD" w14:textId="77777777" w:rsidR="001A5CB5" w:rsidRPr="001A5CB5" w:rsidRDefault="001A5CB5" w:rsidP="001A5CB5"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve">[ ] </w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>User Value:</w:t></w:r><w:r w:rsidRPr="001A5CB5"><w:t xml:space="preserve"> A user can identify the primary refineries processing Venezuelan Heavy Crude within 3 clicks.</w:t></w:r></w:p><w:p w14:paraId="14858875" w14:textId="77777777" w:rsidR="00C34CFD" w:rsidRDefault="00C34CFD"/><w:sectPr w:rsidR="00C34CFD" w:rsidSect="001A5CB5"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="709" w:right="1440" w:bottom="426" w:left="1440" w:header="720" w:footer="720" w:gutter="0"/><w:cols w:space="720"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>