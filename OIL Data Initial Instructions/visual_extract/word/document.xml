><w:bCs/></w:rPr><w:t>1. Modular Architecture Overview</w:t></w:r></w:p><w:p w14:paraId="4134024D" w14:textId="77777777" w:rsidR="00AB6542" w:rsidRPr="00AB6542" w:rsidRDefault="00AB6542" w:rsidP="00AB6542"><w:r w:rsidRPr="00AB6542"><w:t>The engine is divided into three distinct layers to ensure scalability and ease of debugging:</w:t></w:r></w:p><w:p w14:paraId="0349120D" w14:textId="77777777" w:rsidR="00AB6542" w:rsidRPr="00AB6542" w:rsidRDefault="00AB6542" w:rsidP="00AB6542"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00AB6542"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>The Analyst (Logic Layer):</w:t></w:r><w:r w:rsidRPr="00AB6542"><w:t xml:space="preserve"> A Gemini 2.5 Flash agent that queries the Neon DB, identifies trends, and writes the "narrative."</w:t></w:r></w:p><w:p w14:paraId="25463A8A" w14:textId="77777777" w:rsidR="00AB6542" w:rsidRPr="00AB6542" w:rsidRDefault="00AB6542" w:rsidP="00AB6542"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00AB6542"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>The Architect (Configuration Layer):</w:t></w:r><w:r w:rsidRPr="00AB6542"><w:t xml:space="preserve"> A JSON-to-</w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00AB6542"><w:t>ECharts</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00AB6542"><w:t xml:space="preserve"> mapper that converts AI insights into valid visualization code.</w:t></w:r></w:p><w:p w14:paraId="1240945C" w14:textId="77777777" w:rsidR="00AB6542" w:rsidRDefault="00AB6542" w:rsidP="00AB6542"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00AB6542"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>The Canvas (Presentation Layer):</w:t></w:r><w:r w:rsidRPr="00AB6542"><w:t xml:space="preserve"> A Next.js "Smart Component" that renders the charts with a consistent, minimalist aesthetic.</w:t></w:r></w:p><w:p w14:paraId="23B35853" w14:textId="77777777" w:rsidR="00AB6542" w:rsidRPr="00AB6542"